---
/**
 * Displays a single work-experience entry with company logo, role, and
 * date range. Accepts a `<slot>` for an optional description body.
 */

interface Props {
  /** Company or organisation name. */
  company: string;
  /** Path to the company logo image. */
  logo: string;
  /** Start date as an ISO-8601 string (e.g. "2022-01"). */
  from: string;
  /** End date as an ISO-8601 string. Omit for current positions. */
  to?: string;
  /** Job title or role held. */
  role: string;
}

const { company, logo, from, to, role } = Astro.props;

/**
 * Format an ISO date string into a short human-readable form (e.g. "Jan 2024").
 * Uses `Intl.DateTimeFormat` for locale-aware month abbreviations.
 */
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "short",
  }).format(date);
};

const formattedFrom = formatDate(from);
const formattedTo = to ? formatDate(to) : "Present";
const duration = `${formattedFrom} - ${formattedTo}`;
---

<div class="flex gap-4">
  <img
    src={logo}
    alt={`${company} logo`}
    width="16"
    height="16"
    class="w-6 h-6 mt-1 shrink-0"
  />
  <div class="flex-1">
    <div class="flex justify-between items-baseline flex-wrap gap-2">
      <h3 class="font-semibold">{company}</h3>
      <span class="text-stone-400 text-sm">{duration}</span>
    </div>
    <p class="text-sm text-stone-500">{role}</p>
    <div class="text-sm text-stone-600 mt-1">
      <slot />
    </div>
  </div>
</div>
