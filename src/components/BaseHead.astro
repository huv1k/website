---
/**
 * Shared `<head>` fragment included on every page.
 *
 * Responsibilities:
 * - Imports global CSS so styles are present on all routes.
 * - Emits canonical URL, primary meta tags, Open Graph, and Twitter Card tags.
 * - Constructs a dynamic OG image URL by forwarding `title` and `description`
 *   as query parameters to the `/og-image.png` endpoint.
 * - Injects two Schema.org JSON-LD scripts (Person + WebSite) for SEO.
 * - Loads the Seline analytics snippet.
 */
import '../styles/global.css';
import { Font } from 'astro:assets';

export interface Props {
  /** Page title used in `<title>`, meta tags, and the OG image. */
  title: string;
  /** Page description used in meta tags and the OG image. */
  description: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description } = Astro.props as Props;

/**
 * Dynamic OG image URL — passes title and description as query params so each
 * page gets a unique preview card generated by `/og-image.png`.
 */
const ogImageUrl = new URL('/og-image.png', Astro.site);
ogImageUrl.searchParams.set('title', title);
ogImageUrl.searchParams.set('description', description);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="light dark" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
<meta name="generator" content={Astro.generator} />
<Font cssVariable="--font-space-mono" preload />

<!-- Theme init (runs before paint to avoid FOUC) -->
<script is:inline>
  (function () {
    try {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var isDark = stored ? stored === 'dark' : prefersDark;
      document.documentElement.classList.toggle('dark', isDark);
    } catch (_) {}
  })();
</script>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />

<!-- Schema.org structured data -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Lukáš Huvar',
    alternateName: 'Huvik',
    url: 'https://huvik.dev',
    jobTitle: 'Software Developer',
    description:
      'Software developer passionate about React, GraphQL, TypeScript',
    knowsAbout: [
      'React',
      'GraphQL',
      'TypeScript',
      'Web Performance',
      'Frontend Development',
    ],
    sameAs: ['https://github.com/huv1k', 'https://twitter.com/huv1k'],
  })}
>
</script>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Huvik',
    url: 'https://huvik.dev',
    description:
      'Personal site by Lukáš Huvar. A software developer from the Czech Republic. Passionated about React, GraphQL, Typescript.',
    author: {
      '@type': 'Person',
      name: 'Lukáš Huvar',
    },
  })}
>
</script>

<!-- Analytics -->
<script
  async
  src="https://cdn.seline.com/seline.js"
  data-token="3dbfe3e0f5afd12"></script>
